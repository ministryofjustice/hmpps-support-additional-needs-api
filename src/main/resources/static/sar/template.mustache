    {{/nonAlnChallenges}}

    <h2>ALN Screener result entered in SAN</h2>
    {{#alnScreeners}}
        <h3>Screener</h3>
        <table class="summary-list">
            <tr><td>Screening date</td><td>{{ optionalValue (formatDate screenerDate) }}</td></tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Created by</td>
                <td class="data-column-35">Created at</td>
                <td class="data-column-30">Created at prison</td>
            </tr>
            <tr>
                <td>{{ getUserLastName createdBy }}</td>
                <td>{{ optionalValue (formatDate createdAt) }}</td>
                <td>{{ getPrisonName createdAtPrison }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Updated by</td>
                <td class="data-column-35">Updated at</td>
                <td class="data-column-30">Updated at prison</td>
            </tr>
            <tr>
                <td>{{ getUserLastName updatedBy }}</td>
                <td>{{ optionalValue (formatDate updatedAt) }}</td>
                <td>{{ getPrisonName updatedAtPrison }}</td>
            </tr>
        </table>
        <h4>Additional Learning Needs Strengths</h4>
        {{#strengths}}
            <h5>Strength</h5>
            <table class="summary-list">
                <tr><td>From additional learning needs screener</td><td>{{ convertBoolean fromALNScreener }}</td></tr>
                <tr><td>Additional learning needs screener date</td><td>{{ formatDate alnScreenerDate }}</td></tr>
                <tr><td>Active</td><td>{{ convertBoolean active }}</td></tr>
                <tr><td>Strength type</td><td>{{ optionalValue strengthType.code }}</td></tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-30">Created by</td>
                    <td class="data-column-35">Created at</td>
                    <td class="data-column-30">Created at prison</td>
