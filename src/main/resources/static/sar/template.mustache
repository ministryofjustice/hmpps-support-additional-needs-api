<h1 class="title">Support for Additional Needs</h1>
{{#.}}
    <h2>Education Support Plans</h2>
    {{#originalEducationSupportPlan}}
        <h3>Plan</h3>
        <table class="summary-list">
            <tr><td>Has Education, Health and Care Plan</td><td>{{ convertBoolean hasCurrentEhcp }}</td></tr>
            <tr><td>Individual support</td><td>{{ optionalValue individualSupport }}</td></tr>
            <tr><td>Teaching adjustments</td><td>{{ optionalValue teachingAdjustments }}</td></tr>
            <tr><td>Specific teaching skills</td><td>{{ optionalValue specificTeachingSkills }}</td></tr>
            <tr><td>Exam access arrangements</td><td>{{ optionalValue examAccessArrangements }}</td></tr>
            <tr><td>Learning needs support practitioner support</td><td>{{ optionalValue lnspSupport }}</td></tr>
            <tr><td>Learning needs support practitioner support hours</td><td>{{ optionalValue lnspSupportHours }}</td></tr>
            <tr><td>Detail</td><td>{{ optionalValue detail }}</td></tr>
            <tr><td>Created by</td><td>{{ optionalValue planCreatedBy.name }}</td></tr>
            <tr><td>Created by job role</td><td>{{ optionalValue planCreatedBy.jobRole }}</td></tr>
            {{#otherContributors}}
            <tr><td>Other contributor name</td><td>{{ optionalValue name }}</td></tr>
            <tr><td>Other contributor job role</td><td>{{ optionalValue jobRole }}</td></tr>
            {{/otherContributors}}
            {{^otherContributors}}
            <tr><td>Other contributor name</td><td>No Data Held</td></tr>
            <tr><td>Other contributor job role</td><td>No Data Held</td></tr>
            {{/otherContributors}}
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Created by</td>
                <td class="data-column-35">Created at</td>
                <td class="data-column-30">Created at prison</td>
            </tr>
            <tr>
                <td>{{ getUserLastName createdBy }}</td>
                <td>{{ optionalValue (formatDate createdAt) }}</td>
                <td>{{ getPrisonName createdAtPrison }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Updated by</td>
                <td class="data-column-35">Updated at</td>
                <td class="data-column-30">Updated at prison</td>
            </tr>
            <tr>
                <td>{{ getUserLastName updatedBy }}</td>
                <td>{{ optionalValue (formatDate updatedAt) }}</td>
                <td>{{ getPrisonName updatedAtPrison }}</td>
            </tr>
        </table>
    {{/originalEducationSupportPlan}}
    {{^originalEducationSupportPlan}}
        <p>No Data Held</p>
    {{/originalEducationSupportPlan}}

    <h2>Support strategies</h2>
    {{#supportStrategies}}
        <h3>Support strategy</h3>
        <table class="summary-list">
            <tr><td>Active</td><td>{{ convertBoolean active }}</td></tr>
            <tr><td>Archive reason</td><td>{{ optionalValue archiveReason }}</td></tr>
            <tr><td>Support strategy type</td><td>{{ optionalValue supportStrategyType.categoryDescription }}</td></tr>
            <tr><td>Detail</td><td>{{ optionalValue detail }}</td></tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Created by</td>
                <td class="data-column-35">Created at</td>
                <td class="data-column-30">Created at prison</td>
            </tr>
            <tr>
                <td>{{ getUserLastName createdBy }}</td>
                <td>{{ optionalValue (formatDate createdAt) }}</td>
                <td>{{ getPrisonName createdAtPrison }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Updated by</td>
                <td class="data-column-35">Updated at</td>
                <td class="data-column-30">Updated at prison</td>
            </tr>
            <tr>
                <td>{{ getUserLastName updatedBy }}</td>
                <td>{{ optionalValue (formatDate updatedAt) }}</td>
                <td>{{ getPrisonName updatedAtPrison }}</td>
            </tr>
        </table>
    {{/supportStrategies}}
    {{^supportStrategies}}
        <p>No Data Held</p>
    {{/supportStrategies}}

    <h2>Strengths</h2>
    {{#nonAlnStrengths}}
        <h3>Strength</h3>
        <table class="summary-list">
            <tr><td>Active</td><td>{{ convertBoolean active }}</td></tr>
            <tr><td>Archive reason</td><td>{{ optionalValue archiveReason }}</td></tr>
            <tr><td>Strength type</td><td>{{ optionalValue strengthType.code }}</td></tr>
            <tr><td>Strength description</td><td>{{ optionalValue symptoms }}</td></tr>
            <tr>
                <td>How identified</td>
                <td>{{#howIdentified}}{{ . }}{{#unless @last}}, {{/unless}}{{/howIdentified}}</td>
            </tr>
            <tr><td>How identified other</td><td>{{ optionalValue howIdentifiedOther }}</td></tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Created by</td>
                <td class="data-column-35">Created at</td>
                <td class="data-column-30">Created at prison</td>
            </tr>
            <tr>
                <td>{{ getUserLastName createdBy }}</td>
                <td>{{ optionalValue (formatDate createdAt) }}</td>
                <td>{{ getPrisonName createdAtPrison }}</td>
